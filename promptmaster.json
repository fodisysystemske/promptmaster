# APPENDIX C — OK-02 REFERENCE IMPLEMENTATION (`defensive_guardian.py`)

Machine-executable pattern for totem + JIT + sandbox + audit (extend per environment).

```python
import json
import logging
from dataclasses import dataclass
from typing import Callable, List, Dict, Any

@dataclass
class TotemResult:
    passed: bool
    confidence: float
    evidence: str
    sources: List[str]

class DefensiveGuardian:
    def __init__(self, policy_engine, sandbox_executor):
        self.policy_engine = policy_engine
        self.sandbox = sandbox_executor
        self.logger = logging.getLogger(__name__)

    def spin_totem(
        self, intent: str, tool_call: Dict[str, Any], sources: List[Callable]
    ) -> TotemResult:
        results = []
        for source in sources:
            try:
                res = source(intent, tool_call)
                results.append(res)
            except Exception as e:
                results.append(
                    TotemResult(False, 0.0, str(e), [getattr(source, "__name__", "source")])
                )
        passed = all(r.passed for r in results)
        avg_conf = sum(r.confidence for r in results) / len(results) if results else 0.0
        if not passed or avg_conf < 0.95:
            self.logger.critical("TOTEM FAILURE | Intent: %s | Tool: %s", intent, tool_call)
            return TotemResult(
                False,
                avg_conf,
                "Totem failed - one or more sources",
                [r.sources[0] if r.sources else "?" for r in results],
            )
        return TotemResult(True, avg_conf, "All sources passed", [str(s) for s in sources])

    def issue_jit_token(self, tool_call: Dict) -> str:
        """Replace with real STS / vault / cloud IAM short-lived credential."""
        raise NotImplementedError

    def audit_log(self, intent, tool_call, result, totem: TotemResult) -> None:
        self.logger.info(
            json.dumps(
                {
                    "intent": intent,
                    "tool": tool_call,
                    "totem": {
                        "passed": totem.passed,
                        "confidence": totem.confidence,
                        "evidence": totem.evidence,
                    },
                }
            )
        )

    def secure_execute(
        self, tool_call: Dict, intent: str, grounding_sources: List[Callable]
    ):
        totem = self.spin_totem(intent, tool_call, grounding_sources)
        if not totem.passed:
            raise RuntimeError(f"Security Totem failed: {totem.evidence}")
        token = self.issue_jit_token(tool_call)
        result = self.sandbox.execute(tool_call, token)
        self.audit_log(intent, tool_call, result, totem)
        return result


def policy_check(intent, tool_call) -> TotemResult:
    return TotemResult(True, 0.98, "Policy OK", ["policy_engine"])


def sandbox_simulator(intent, tool_call) -> TotemResult:
    return TotemResult(True, 0.96, "Simulation clean", ["sandbox"])
```

Wire `grounding_sources` to your OPA/Cedar evaluation, real sandbox runner, and intent-alignment oracle in production.

